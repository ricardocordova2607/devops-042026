pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "ricardocs82/app-controle:latest"
    }

    stages {

        stage('Checkout') {
            steps {

                echo 'Checking out repository...'

                checkout scm
            }
        }

        stage('Build Images') {
            steps {

                script {

                    docker.withRegistry('https://index.docker.io/v1/', 'dockerhub') {

                        sh '''
                            docker build -t $DOCKER_IMAGE .
                        '''

                        sh '''
                            docker push $DOCKER_IMAGE
                        '''
                    }
                }
            }
        }

        stage('Security Scan (Trivy)') {
            steps {

                sh '''
                    trivy image $DOCKER_IMAGE
                '''
            }
        }

        stage('Test in Containers') {
            steps {

                sh '''
                    docker run -d --name app-teste -p 8080:80 $DOCKER_IMAGE
                '''

                sh '''
                    docker ps
                '''

                sh '''
                    docker rm -f app-teste
                '''
            }
        }

        stage('Deploy to Production') {
            steps {

                echo 'Deploy realizado com sucesso!'
            }
        }
    }

    post {

        success {

            slackSend(
                teamDomain: 'rcs',
                channel: '#ci-devops',
                tokenCredentialId: 'slack-token',
                botUser: true,
                message: 'Pipeline executado com sucesso!'
            )
        }

        failure {

            slackSend(
                teamDomain: 'rcs',
                channel: '#ci-devops',
                tokenCredentialId: 'slack-token',
                botUser: true,
                message: 'Pipeline falhou!'
            )
        }
    }
}
